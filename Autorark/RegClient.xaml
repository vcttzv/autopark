<Window x:Class="Autorark.RegClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Autorark"
        mc:Ignorable="d"
        Title="Регистрация клиента" MinHeight="600" MinWidth="400" Height="600" Width="400">

    <Window.Resources>
        <ResourceDictionary Source="Styles.xaml" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="10" />
            <RowDefinition Height="48" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="272" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Background="#2C2C2C" Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="image 1.png" Height="50" Width="50" HorizontalAlignment="Left" Margin="10,0,20,0"/>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
        <Run FontSize="24" FontWeight="DemiBold" Foreground="White">Регистрация клиента</Run>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Имя</Run>
        </TextBlock>
        <TextBox x:Name="name" MaxLength="50" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="4" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Фамилия</Run>
        </TextBlock>
        <TextBox x:Name="lastname" MaxLength="50" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="6" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Дата рождения</Run>
        </TextBlock>
        <DatePicker x:Name="birthdate" Grid.Row="7" Grid.Column="1" Style="{StaticResource DatePicker}" />

        <TextBlock Grid.Row="8" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Номер телефона</Run>
        </TextBlock>
        <TextBox x:Name="telephone" MaxLength="11" Grid.Row="9" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="10" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Адрес регистрации</Run>
        </TextBlock>
        <TextBox x:Name="address" Grid.Row="11" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="12" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Номер и серия паспорта</Run>
        </TextBlock>
        <TextBox x:Name="passport" MaxLength="10" Grid.Row="13" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <Grid Grid.Column="1" Grid.Row="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="85" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Button Content="Сохранить" Width="110" Height="40" Grid.Column="0" Style="{StaticResource AccentButton}" x:Name="save" Click="Save_Click" />
            <Button Content="Отмена" Width="85" Height="40" Grid.Column="2" Style="{StaticResource Button}" x:Name="cancel" Click="Cancel_Click" />
        </Grid>

    </Grid>
</Window>

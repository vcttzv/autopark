<Window x:Class="Autorark.Tables"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Autorark"
        mc:Ignorable="d"
        Title="Tables" Height="765" Width="1300" MinHeight="765" MinWidth="1300"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary Source="Styles.xaml" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="45"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="85"></RowDefinition>
            <RowDefinition Height="5"></RowDefinition>
            <RowDefinition MinHeight="465"></RowDefinition>
            <RowDefinition Height="15"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="15"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="22"></ColumnDefinition>
            <ColumnDefinition MinWidth="1235"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Background="#2C2C2C" Orientation="Horizontal" VerticalAlignment="Center" Height="50">
            <Image Source="image 1.png" Height="50" Width="50" HorizontalAlignment="Left" Margin="10,0,20,0"/>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
        <Run FontSize="24" FontWeight="DemiBold" Foreground="White">Просмотр таблиц</Run>
            </TextBlock>
        </StackPanel>

        <Grid Grid.ColumnSpan="2" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"></ColumnDefinition>
                <ColumnDefinition Width="120"></ColumnDefinition>
                <ColumnDefinition Width="120"></ColumnDefinition>
                <ColumnDefinition Width="120"></ColumnDefinition>
                <ColumnDefinition Width="120"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="5" BorderBrush="#B2B2B2" BorderThickness="0,0,0,1" />
            <Button Grid.Column="0" Content="Транспорт" Style="{StaticResource InactiveTab}" x:Name="transport" Click="Transport_Click" />
            <Button Grid.Column="1" Content="Операции" Style="{StaticResource InactiveTab}" x:Name="operations" Click="Operations_Click" />
            <Button Grid.Column="2" Content="Сотрудники" Style="{StaticResource InactiveTab}" x:Name="employees" Click="Employees_Click" />
            <Button Grid.Column="3" Content="Клиенты" Style="{StaticResource InactiveTab}" x:Name="clients" Click="Clients_Click" />
            <Button Grid.Column="4" Content="Автопарки" Style="{StaticResource InactiveTab}" x:Name="parks" Click="Parks_Click" />
        </Grid>

        <!-- Транспорт -->
        <Grid Grid.Row="3" Grid.Column="1" x:Name="filtr_ts" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="275" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="275" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="275" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                Тип транспорта
            </TextBlock>
            <ComboBox x:Name="type" Grid.Row="1" Grid.Column="0" Style="{StaticResource ComboBox}" SelectionChanged="Type_SelectionChanged">
                <ComboBoxItem>
                    Легковой автомобиль общего назначения
                </ComboBoxItem>
                <ComboBoxItem>
                    Специальный легковой автомобиль
                </ComboBoxItem>
                <ComboBoxItem>
                    Грузовой автомобиль общего назначения
                </ComboBoxItem>
                <ComboBoxItem>
                    Специальный грузовой автомобиль
                </ComboBoxItem>
                <ComboBoxItem>
                    Грузопассажирский автомобиль
                </ComboBoxItem>
                <ComboBoxItem>
                    Автомобиль-тягач
                </ComboBoxItem>
                <ComboBoxItem>
                    Автобус общего назначения
                </ComboBoxItem>
                <ComboBoxItem>
                    Специальный автобус
                </ComboBoxItem>
                <ComboBoxItem>
                    Микроавтобус
                </ComboBoxItem>
            </ComboBox>

            <TextBlock Grid.Column="2" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                Размещение в автопарке
            </TextBlock>
            <ComboBox x:Name="autopark" Grid.Row="1" Grid.Column="2" Style="{StaticResource ComboBox}" SelectionChanged="Autopark_SelectionChanged">

            </ComboBox>

            <TextBlock Grid.Column="4" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                Статус
            </TextBlock>
            <ComboBox x:Name="status" Grid.Row="1" Grid.Column="4" Style="{StaticResource ComboBox}" SelectionChanged="Status_SelectionChanged">
                <ComboBoxItem>
                    В эксплуатации
                </ComboBoxItem>
                <ComboBoxItem>
                    На обслуживании
                </ComboBoxItem>
                <ComboBoxItem>
                    Неисправно
                </ComboBoxItem>
                <ComboBoxItem>
                    Доступно для аренды/перевозки
                </ComboBoxItem>
                <ComboBoxItem>
                    Выведено из эксплуатации
                </ComboBoxItem>
                <ComboBoxItem>
                    Забронировано
                </ComboBoxItem>
                <ComboBoxItem>
                    На учёте
                </ComboBoxItem>
            </ComboBox>

            <Button Content="Обновить" Height="40"  Grid.Row="1" Grid.Column="6" VerticalAlignment="Bottom" Style="{StaticResource AccentButton}" x:Name="button_filter" Click="Button_filter_Click" />

            <TextBlock x:Name="unsave" Grid.Column="7" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0" FontStyle="Italic" Foreground="#FFB2B1B1">
                <Run FontSize="16">
                    Есть несохранённые параметры
                </Run>
            </TextBlock>
        </Grid>

        <TextBlock Grid.Column="1" Grid.Row="3" x:Name="select_db" Visibility="Collapsed">
            Выберите информационный раздел.
        </TextBlock>
        <TextBlock Grid.Column="1" Grid.Row="5" x:Name="no_results" Visibility="Collapsed">
            Результаты не найдены.
        </TextBlock>

        <DataGrid Margin="0,0,22,0" Grid.Column="1" Grid.Row="5" x:Name="transport_grid" AutoGenerateColumns="False" IsReadOnly="False" Visibility="Collapsed">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ts_id}" />
                <DataGridTextColumn Header="Рег. номер" Binding="{Binding template}" />
                <DataGridTextColumn Header="Марка" Binding="{Binding mark}" />
                <DataGridTextColumn Header="Тип" Binding="{Binding type}" />
                <DataGridTextColumn Header="Стоимость аренды" Binding="{Binding rent_price}" />
                <DataGridTextColumn Header="Полная себестоимость" Binding="{Binding full_price}" />
                <DataGridTextColumn Header="Местоположение (Автопарк)" Binding="{Binding base_name}" />
                <DataGridTextColumn Header="Статус" Binding="{Binding status}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Операции -->
        <Grid Grid.Row="3" Grid.Column="1" x:Name="filtr_ops" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="275" />
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="275" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                Даты действия договора
            </TextBlock>

            <TextBlock Grid.Column="0" Grid.Row="1" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                С
            </TextBlock>
            <DatePicker x:Name="min_date" Grid.Column="1" Grid.Row="1" Style="{StaticResource DatePicker}" VerticalAlignment="Center" Height="40" />
            <TextBlock Grid.Column="2" Grid.Row="1" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                по
            </TextBlock>
            <DatePicker x:Name="max_date" Grid.Column="3" Grid.Row="1" Style="{StaticResource DatePicker}" VerticalAlignment="Center" Height="40" />

            <Button Content="Обновить" Height="40" Grid.Row="1" Grid.Column="5" VerticalAlignment="Bottom" Style="{StaticResource AccentButton}" x:Name="button_filter_ops" Click="Button_filter_ops_Click" />

            <TextBlock x:Name="unsave_ops" Grid.Column="7" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0" FontStyle="Italic" Foreground="#FFB2B1B1">
                <Run FontSize="16">
                    Есть несохранённые параметры
                </Run>
            </TextBlock>
        </Grid>
        
        <DataGrid Margin="0,0,22,0" Grid.Column="1" Grid.Row="5" x:Name="operation_grid" AutoGenerateColumns="False" IsReadOnly="False" Visibility="Collapsed">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding operation_id}" />
                <DataGridTextColumn Header="Работник заключчивший договор" Binding="{Binding employee}" />
                <DataGridTextColumn Header="Клиент" Binding="{Binding client}" />
                <DataGridTextColumn Header="Транспортное средство" Binding="{Binding template}" />
                <DataGridTextColumn Header="Дата заключения договора" Binding="{Binding date}" />
                <DataGridTextColumn Header="Дата окончания аренды" Binding="{Binding rent_for}" />
                <DataGridTextColumn Header="Стоимость аренды" Binding="{Binding price}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Сотрудники -->
        <DataGrid Margin="0,0,22,0" Grid.Column="1"  Grid.Row="3" Grid.RowSpan="3" x:Name="employee_grid" AutoGenerateColumns="False" IsReadOnly="False" Visibility="Collapsed">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding emp_id}" />
                <DataGridTextColumn Header="Логин" Binding="{Binding login}" />
                <DataGridTextColumn Header="Имя" Binding="{Binding name}" />
                <DataGridTextColumn Header="Фамилия" Binding="{Binding lastname}" />
                <DataGridTextColumn Header="Электронная почта" Binding="{Binding email}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Клиенты -->
        <DataGrid Margin="0,0,22,0" Grid.Column="1" Grid.Row="3" Grid.RowSpan="3" x:Name="client_grid" AutoGenerateColumns="False" IsReadOnly="False" Visibility="Collapsed">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding client_id}" />
                <DataGridTextColumn Header="Имя" Binding="{Binding name}" />
                <DataGridTextColumn Header="Фамилия" Binding="{Binding lastname}" />
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding birth}" />
                <DataGridTextColumn Header="Номер телефона" Binding="{Binding phone}" />
                <DataGridTextColumn Header="Адрес регистрации" Binding="{Binding address}" />
                <DataGridTextColumn Header="Серия и номер паспорт" Binding="{Binding passport}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Автопарки -->
        <Grid Grid.Row="3" Grid.Column="1" x:Name="filtr_bases" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="275" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0" FontSize="16" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                Свободных парковочных мест
            </TextBlock>
            <TextBlock Grid.Column="0" Grid.Row="1" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                Более
            </TextBlock>
            <TextBox x:Name="min_spaces" Grid.Column="1" Grid.Row="1" Style="{StaticResource TextBox}" />

            <Button Content="Обновить" Height="40" Grid.Row="1" Grid.Column="3" VerticalAlignment="Bottom" Style="{StaticResource AccentButton}" x:Name="button_filter_bases" Click="Button_filter_bases_Click" />

            <TextBlock x:Name="unsave_bases" Grid.Column="4" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0" FontStyle="Italic" Foreground="#FFB2B1B1">
                <Run FontSize="16">
                    Есть несохранённые параметры
                </Run>
            </TextBlock>
        </Grid>
        
        <DataGrid Margin="0,0,22,0" Grid.Column="1" Grid.Row="5" x:Name="base_grid" AutoGenerateColumns="False" IsReadOnly="True" Visibility="Collapsed">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding base_id}" />
                <DataGridTextColumn Header="Название автопарка" Binding="{Binding base_name}" />
                <DataGridTextColumn Header="Адрес размещения" Binding="{Binding address}" />
                <DataGridTextColumn Header="Стоимость годовой аренды" Binding="{Binding year_rent}" />
                <DataGridTextColumn Header="Аренда оплачена до" Binding="{Binding rent_for}" />
                <DataGridTextColumn Header="Всего парковочных мест" Binding="{Binding max_ts}" />
                <DataGridTextColumn Header="Свободных парковочных мест" Binding="{Binding free_spots}" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="7" Grid.Column="1" Width="130" HorizontalAlignment="Left" Content="Вернуться" Style="{StaticResource Button}" x:Name="back" Click="Back_Click" />
        <Button Margin="0,0,22,0" Grid.Row="7" Grid.Column="1" Width="190" HorizontalAlignment="Right" Content="Сформировать отчёт" Style="{StaticResource AccentButton}" />
    </Grid>
</Window>
<Window x:Class="Autorark.RegTS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Autorark"
        mc:Ignorable="d"
        Title="Регистрация транспорта" MinHeight="680" MinWidth="400" Height="680" Width="400"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary Source="Styles.xaml" />
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="272" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="30" />
            <RowDefinition Height="40" />
            <RowDefinition Height="10" />
            <RowDefinition Height="48" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Background="#2C2C2C" Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="image 1.png" Height="50" Width="50" HorizontalAlignment="Left" Margin="10,0,20,0"/>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
        <Run FontSize="24" FontWeight="DemiBold" Foreground="White">Регистрация транспорта</Run>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Регистрационный номер</Run>
        </TextBlock>
        
        <TextBox x:Name="template" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="4" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Марка</Run>
        </TextBlock>
        <TextBox x:Name="mark" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="6" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Тип ТС</Run>
        </TextBlock>
        <ComboBox x:Name="type" Grid.Row="7" Grid.Column="1" Style="{StaticResource ComboBox}">
            <ComboBoxItem>
                Легковой автомобиль общего назначения
            </ComboBoxItem>
            <ComboBoxItem>
                Специальный легковой автомобиль
            </ComboBoxItem>
            <ComboBoxItem>
                Грузовой автомобиль общего назначения
            </ComboBoxItem>
            <ComboBoxItem>
                Специальный грузовой автомобиль
            </ComboBoxItem>
            <ComboBoxItem>
                Грузопассажирский автомобиль
            </ComboBoxItem>
            <ComboBoxItem>
                Автомобиль-тягач
            </ComboBoxItem>
            <ComboBoxItem>
                Автобус общего назначения
            </ComboBoxItem>
            <ComboBoxItem>
                Специальный автобус
            </ComboBoxItem>
            <ComboBoxItem>
                Микроавтобус
            </ComboBoxItem>
        </ComboBox>

        <TextBlock Grid.Row="8" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Статус</Run>
        </TextBlock>
        <ComboBox x:Name="status" Grid.Row="9" Grid.Column="1" Style="{StaticResource ComboBox}">
            <ComboBoxItem>
                В эксплуатации
            </ComboBoxItem>
            <ComboBoxItem>
                На обслуживании
            </ComboBoxItem>
            <ComboBoxItem>
                Неисправно
            </ComboBoxItem>
            <ComboBoxItem>
                Доступно для аренды/перевозки
            </ComboBoxItem>
            <ComboBoxItem>
                Выведено из эксплуатации
            </ComboBoxItem>
            <ComboBoxItem>
                Забронировано
            </ComboBoxItem>
            <ComboBoxItem>
                На учёте
            </ComboBoxItem>
        </ComboBox>

        <TextBlock Grid.Row="10" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Автопарк</Run>
        </TextBlock>
        <ComboBox x:Name="autopark" Grid.Row="11" Grid.Column="1" Style="{StaticResource ComboBox}">
            
        </ComboBox>

        <TextBlock Grid.Row="12" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Полная стоимость (в рублях)</Run>
        </TextBlock>
        <TextBox x:Name="full_price" Grid.Row="13" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="14" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Стоимость аренды (в день)</Run>
        </TextBlock>
        <TextBox x:Name="rent_price" Grid.Row="15" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <Grid Grid.Column="1" Grid.Row="17">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="85" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Button Content="Сохранить" Width="110" Height="40" Grid.Column="0" Style="{StaticResource AccentButton}" x:Name="save" Click="Save_Click" />
            <Button Content="Отмена" Width="85" Height="40" Grid.Column="2" Style="{StaticResource Button}" x:Name="cancel" Click="Cancel_Click" />
        </Grid>
    </Grid>
</Window>

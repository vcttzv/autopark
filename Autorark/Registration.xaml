<Window x:Class="Autorark.Registration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Autorark"
        mc:Ignorable="d"
        Title="Registration" Height="650" Width="400" MinHeight="650" MinWidth="400">

    <Window.Resources>
        <ResourceDictionary Source="Styles.xaml" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="48"></RowDefinition>
            <RowDefinition Height="48"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="272"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Background="#2C2C2C" Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="image 1.png" Height="50" Width="50" HorizontalAlignment="Left" Margin="10,0,20,0"/>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
        <Run FontSize="24" FontWeight="DemiBold" Foreground="White">Регистрация</Run>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Имя</Run>
        </TextBlock>
        <TextBox x:Name="box_name" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="4" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Фамилия</Run>
        </TextBlock>
        <TextBox x:Name="box_lastname" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="6" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Логин</Run>
        </TextBlock>
        <TextBox x:Name="box_login" Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="8" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Электронная почта</Run>
        </TextBlock>
        <TextBox x:Name="box_email" Grid.Row="9" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="10" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Пароль</Run>
        </TextBlock>
        <PasswordBox x:Name="box_password" Grid.Row="11" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource PasswordBox}"></PasswordBox>

        <TextBlock Grid.Row="12" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Повторите пароль</Run>
        </TextBlock>
        <PasswordBox x:Name="box_password_confirm" Grid.Row="13" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource PasswordBox}"></PasswordBox>

        <Button Content="Зарегистрироваться" Width="272" Height="36" Grid.Column="1" Grid.Row="15" Style="{StaticResource AccentButton}" x:Name="register" Click="Register" />
        <Button Content="Есть учётная запись" Width="272" Height="36" Grid.Column="1" Grid.Row="16" Style="{StaticResource Button}" x:Name="auth" Click="Auth_Click" />

    </Grid>
</Window>

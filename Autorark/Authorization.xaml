<Window x:Class="Autorark.Authorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Autorark"
        mc:Ignorable="d"
        Title="Автопарк: Авторизация" Height="350" Width="400" MinHeight="350" MinWidth="370">

    <Window.Resources>
        <ResourceDictionary Source="Styles.xaml" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="48"></RowDefinition>
            <RowDefinition Height="48"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="272"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Background="#2C2C2C" Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="image 1.png" Height="50" Width="50" HorizontalAlignment="Left" Margin="10,0,20,0"/>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
        <Run FontSize="24" FontWeight="DemiBold" Foreground="White">Авторизация</Run>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Логин</Run>
        </TextBlock>
        <TextBox x:Name="box_login" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource TextBox}"></TextBox>

        <TextBlock Grid.Row="3" Grid.Column="1" VerticalAlignment="Center">
            <Run FontSize="16">Пароль</Run>
        </TextBlock>
        <PasswordBox x:Name="box_password" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="272" Height="40" Padding="8" Style="{StaticResource PasswordBox}"></PasswordBox>

        <Button x:Name="login" Content="Войти" Width="272" Height="36" Grid.Column="1" Grid.Row="6" Style="{StaticResource AccentButton}" Click="Login_Click" />
        <Button Content="Регистрация" Width="272" Height="36" Grid.Column="1" Grid.Row="7" Style="{StaticResource Button}" x:Name="reg" Click="Reg_Click" />
    </Grid>
</Window>
